# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Adaptive AI Engine"
APP_VERSION="1.0.0"
DEBUG=false
SECRET_KEY=change-me-use-openssl-rand-hex-32

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./adaptive_ai.db
# POSTGRES_URL=postgresql+asyncpg://user:pass@localhost:5432/adaptive_ai

# ─── Cache (optional) ─────────────────────────────────────────────────────────
REDIS_ENABLED=false
# REDIS_URL=redis://localhost:6379

# ─── Vector DB ────────────────────────────────────────────────────────────────
CHROMA_ENABLED=true
CHROMA_PERSIST_DIR=./memory/chroma

# ─── AI Providers (add at least one) ──────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o

ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# ─── Orchestrator ─────────────────────────────────────────────────────────────
MAX_RETRIES=3
MODEL_SELECTION_STRATEGY=adaptive
# Options: adaptive | round-robin | cost-optimized

# ─── Security ─────────────────────────────────────────────────────────────────
RATE_LIMIT=60/minute
MAX_PROMPT_LENGTH=8000
ENABLE_AUDIT_LOG=true
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
